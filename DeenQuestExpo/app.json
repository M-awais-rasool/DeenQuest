{
  "expo": {
    "name": "DeenQuestExpo",
    "slug": "deenquestexpo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "deenquest",
    "plugins": [
      [
        "expo-notifications",
        {
          "defaultChannel": "default"
        }
      ],
      "expo-font",
      "expo-asset",
      [
        "@g9k/expo-dynamic-app-icon",
        {
          "onfire": {
            "ios": "./assets/logo/logo-1.png",
            "android": {
              "foregroundImage": "./assets/logo/logo-1.png",
              "backgroundColor": "#000000"
            }
          },
          "worried": {
            "ios": "./assets/logo/logo-2.png",
            "android": {
              "foregroundImage": "./assets/logo/logo-2.png",
              "backgroundColor": "#000000"
            }
          },
          "fading": {
            "ios": "./assets/logo/logo-3.png",
            "android": {
              "foregroundImage": "./assets/logo/logo-3.png",
              "backgroundColor": "#000000"
            }
          },
          "sleeping": {
            "ios": "./assets/logo/logo-4.png",
            "android": {
              "foregroundImage": "./assets/logo/logo-4.png",
              "backgroundColor": "#000000"
            }
          },
          "celebrating": {
            "ios": "./assets/logo/logo-5.png",
            "android": {
              "foregroundImage": "./assets/logo/logo-5.png",
              "backgroundColor": "#000000"
            }
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0B1517"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.awaisrasool.DeenQuestExpo",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo/logo.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.awaisrasool.DeenQuestExpo"
    },
    "web": {
      "favicon": "./assets/logo/logo.png"
    },
    "extra": {
      "eas": {
        "projectId": "e7b64664-fdf0-4e44-8a22-69c519ec7417"
      }
    },
    "owner": "awais-rasool"
  }
}
