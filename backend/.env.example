APP_ENV=development

# Service ports
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
AUTH_SERVICE_HOST=0.0.0.0
AUTH_SERVICE_PORT=8081
CORE_SERVICE_HOST=0.0.0.0
CORE_SERVICE_PORT=8082
WORKER_SERVICE_HOST=0.0.0.0
WORKER_SERVICE_PORT=8083

# Service URLs used by gateway
AUTH_SERVICE_URL=http://auth-service:8081
CORE_SERVICE_URL=http://core-service:8082

# MongoDB
MONGO_URI=mongodb://mongo:27017
MONGO_AUTH_DB=deenquest_auth
MONGO_CORE_DB=deenquest_core
MONGO_WORKER_DB=deenquest_worker

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Kafka
KAFKA_BROKERS=kafka:9092

# JWT
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional migration source DSN (for cmd/migrate)
POSTGRES_DSN=postgres://user:pass@localhost:5432/talentflow?sslmode=disable
